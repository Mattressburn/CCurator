{
  "manifest_version": 3,
  "name": "CCurate",
  "version": "4.0.0",
  "description": "Extract, normalize, dedupe, and package Salesforce case activity preview rows for LLM handoff.",
  "permissions": [
    "activeTab",
    "tabs",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "*://*.salesforce.com/*",
    "*://*.lightning.force.com/*",
    "*://*.force.com/*"
  ],
  "action": {
    "default_title": "CCurate",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ccurate-tool@yourdomain.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}